{
  "name": "source-pane",
  "version": "3.1.1-1",
  "description": "Solid-compatible Panes: Source editor",
  "main": "lib/source-pane.js",
  "files": [
    "/lib",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "clean": "rm -rf lib",
    "build": "npm run clean && npm run build-dist",
    "build-dist": "webpack --progress",
    "dev": "sh -c 'npm run watch-dist & npm run start'",
    "watch:workspace": "npm run watch-dist",
    "watch-dist": "webpack --watch --progress",
    "lint": "eslint",
    "lint-fix": "eslint --fix",
    "test": "jest --no-coverage",
    "test-coverage": "jest --coverage --collectCoverageFrom=src/**/*.[jt]s",
    "prepublishOnly": "npm run test && npm run build",
    "preversion": "npm run lint && npm test",
    "start": "webpack serve --config webpack.dev.config.mjs --open"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SolidOS/source-pane.git"
  },
  "keywords": [
    "solid",
    "source",
    "decentralized",
    "web",
    "rdf",
    "ldp",
    "linked",
    "pane",
    "app",
    "data"
  ],
  "author": "Tim Berners-Lee <timbl@mit.edu>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SolidOS/source-pane/issues"
  },
  "homepage": "https://github.com/SolidOS/source-pane",
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-env": "^7.28.6",
    "@babel/preset-typescript": "^7.29.7",
    "@testing-library/dom": "^10.4.1",
    "babel-loader": "^10.0.0",
    "babel-plugin-inline-import": "^3.0.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.39.2",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-fetch-mock": "^3.0.3",
    "node-polyfill-webpack-plugin": "^4.1.0",
    "pane-registry": "3.1.2-0",
    "rdflib": "2.3.9",
    "solid-logic": "4.0.8-0",
    "solid-ui": "3.1.3-5",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.4.0",
    "webpack": "^5.97.1",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "patch-package": "^8.0.1"
  },
  "solidosDependencies": [
    "rdflib",
    "solid-logic",
    "pane-registry",
    "solid-ui"
  ]
}
